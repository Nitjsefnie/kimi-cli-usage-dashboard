# Postgres
DATABASE_URL_VIZ=postgresql:///kimi_viz
# External users DB (PBKDF2 web_password_hash lookups, read-only)
DATABASE_URL_AUTH=postgresql:///users

# R2 (S3 API). For a local mirror, set R2_ENDPOINT=file:///path/to/r2/
# and leave the access keys empty.
R2_ENDPOINT=file:///tmp/r2/
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=kimi

# Auth + admin
ADMIN_TOKEN=change-me-32-byte-random
COOKIE_SECURE=1

# Versioning — bump to invalidate every parsed session row.
# Must match src/parser.js window.PARSER_VERSION.
PARSER_VERSION=4
